# Backend (Django) - copy to .env and adjust
# Used when connecting with a frontend that calls this API

# ---------- Database ----------
# Use SQLite for local run (default). Set USE_SQLITE=false to use MySQL.
USE_SQLITE=True
# MySQL (when USE_SQLITE=false)
MYSQL_DATABASE=backend_db
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_HOST=localhost
MYSQL_PORT=3306

# ---------- Django ----------
DJANGO_SECRET_KEY=your-secret-key-here
DJANGO_DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# ---------- Frontend / API (for CORS and frontend .env) ----------
# Comma-separated origins allowed to call the API (e.g. React/Vite dev server)
FRONTEND_URL=http://localhost:3000
# Optional: full API base URL (frontend can use this in its own .env)
API_BASE_URL=http://localhost:8000
